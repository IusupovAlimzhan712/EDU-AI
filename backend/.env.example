# ============================================================
# EduAI Backend Environment Configuration
# Copy this file to `.env` and fill in the values marked with <-- FILL THIS
# ============================================================

# --- Flask --------------------------------------------------
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# --- Security keys (REQUIRED) -------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                       # <-- FILL THIS (random 64-char hex string)
JWT_SECRET_KEY=                   # <-- FILL THIS (different random 64-char hex string)

# JWT token lifetimes (seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# --- Database (MySQL) ---------------------------------------
# Create the database first: CREATE DATABASE eduai CHARACTER SET utf8mb4;
DB_HOST=localhost
DB_PORT=3306
DB_USER=root                      # <-- FILL THIS (your MySQL user)
DB_PASSWORD=                      # <-- FILL THIS (your MySQL password)
DB_NAME=eduai

# --- CORS ---------------------------------------------------
# The URL the frontend dev server runs on (Vite default = 3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Password reset -----------------------------------------
# Token lifetime in seconds (3600 = 1 hour)
PASSWORD_RESET_TOKEN_EXPIRES=3600

# Set to 1 in development to return the reset token in the API response
# (skipping email entirely). Set to 0 in production when SMTP is configured.
DEV_RETURN_RESET_TOKEN=1

# --- Email (OPTIONAL - only needed if DEV_RETURN_RESET_TOKEN=0) ---
SMTP_HOST=                        # <-- FILL THIS (e.g. smtp.gmail.com) - OPTIONAL
SMTP_PORT=587
SMTP_USER=                        # <-- FILL THIS - OPTIONAL
SMTP_PASSWORD=                    # <-- FILL THIS - OPTIONAL
SMTP_FROM=noreply@eduai.local

# --- Frontend URL (used in password-reset emails) -----------
FRONTEND_URL=http://localhost:3000

# ============================================================
# RESERVED FOR PHASE 3 (AI Integration)
# Uncomment + fill when starting Phase 3 in Week 7
# ============================================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b           # or mistral:7b, depends on your RAM
